# Copie este arquivo para .env e preencha com seus valores reais
# No Railway, essas mesmas chaves vão na aba "Variables"

# String de conexão do MongoDB Atlas (gratuito em mongodb.com/cloud/atlas)
MONGODB_URI=mongodb+srv://usuario:senha@cluster.mongodb.net/riorise

# Uma senha grande e aleatória, só pra assinar os tokens de login
JWT_SECRET=troque-isso-por-uma-senha-aleatoria-grande-aqui

# Porta do servidor (Railway define automaticamente, pode deixar 3000)
PORT=3000
